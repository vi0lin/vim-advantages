export class VimAdvantageFinder
  static var filename = ".vim-advantages"
  static var fallback = "~/" .. VimAdvantageFinder.filename
  static def Init(fallback_path: string)
    VimAdvantageFinder.fallback = fallback
  enddef
  static def GetDir(cwd: string): string
    var path = split(cwd, '/')
    var result = ""
    var ret = '/' .. join(path[0 : len(path) ], '/')
    if filereadable(ret)
      ret = '/' .. join(path[0 : len(path) - 2 ], '/')
    endif
    return ret
  enddef
  var dir = fnamemodify(cwd, ':h')
  static def GetParentDir(cwd: string): string
    var path = [ '' ]
    extend(path, split(cwd, '/'))
    var ret = join(path[0 : len(path) - 2], '/')
    if ret == ''
      ret = '/'
    endif
    return ret
  enddef
  static def LookUp(cwd: string): string
    var path = VimAdvantageFinder.GetDir(cwd)
    var check = path .. '/' .. VimAdvantageFinder.filename
    if filereadable(check)
      return check
    else
      return ''
    endif
  enddef
  static def FindAll(cwd: string): list<string>
    var result = []
    var find = ""
    var x = ""
    var path = cwd
    while true
      x = VimAdvantageFinder.LookUp(path)
      if x == ''
        path = VimAdvantageFinder.GetParentDir(path)
      else
        extend(result, [ x ])
        path = VimAdvantageFinder.GetParentDir(path)
      endif
      if find == VimAdvantageFinder.fallback
        break
      elseif path == '/'
        break
      endif
    endwhile
    return result
  enddef
endclass
VimAdvantageFinder.Init('~/')

