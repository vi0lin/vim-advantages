export class AssignmentFileReader
  static def Read()
    var files = VimAdvantageFinder.FindAll(getcwd())
    for f in files
      echo f
       # extend(Assignment.assignments, json_decode(join(readfile(f), "\n")))
       # extend(Assignment.assignments, [ "TEST" ])
    endfor
  enddef
endclass

export class AssignmentFileWriter
  static def Write()
  enddef
endclass

abstract class Dump
  abstract def ToDict(): dict<any>
  def Dump(): string
    var result = ""
    for [k,v] in items(this.ToDict())
      # result .= $"{k}: {v}"
      result = result .. " " .. k .. ": " .. v
    endfor
    return result
  enddef
  # def ToString(): string
  #   return join([this.name,this.command],' ')
  #   return this.Dump()
  # enddef
endclass

interface Assignable
  def Assign(name: string, command: string)
endinterface

enum AssignmentRange
  Global,
  Tab,
  Buffer,
  Window
endenum

# there is no forward declaration / predeclaration in vim.
# type object does not exist in my vim binary
# interface seems to be the niciest path
interface Leaf
endinterface

export class Buffer implements Leaf
  def new(window: Leaf)
    window.buffer = this
  enddef
endclass

export class Window implements Leaf
  static var buffer: Buffer
  static def AssociateBufWin()
    echo "Associating"
  enddef
  static def DeassociateBufWin()
    echo "Deassociating"
  enddef
  static def Print(message: string)
    echo message
  enddef
endclass

export class Tab implements Leaf
  static var windows: list<Window>
endclass

export class Global implements Leaf
  static var global: Global
  static var tabs: list<Tab>
endclass

interface Branch
endinterface

export class VimInstance extends Global implements Branch
  static def Print(message: string)
    echo "VimInstance" .. " " .. message
  enddef
endclass

# export def VimInstancePrint(message: string)
#   VimInstance.Print(message)
# enddef

enum AssignmentBinding
  File,
  Folder,
  Project,
  GitProject
endenum

export class Command extends Dump implements Assignable
  static var commands: list<Command> = []
  static def ShowCommands()
    for c in Command.commands
      echo c
    endfor
  enddef
  var name = ""
  var command = ""
  def new(name: string, command: string)
    this.name = name
    this.command = command
    call extend(Command.commands, [ this ])
  enddef
  def Assign(name: string, command: string)
  enddef
  def Execute()
  enddef
  def ToDict(): dict<any>
    return {
      name: this.name,
      command: this.command,
    }
  enddef
endclass

interface ExecutionBehaviour
  def Execute(command: Command)  
endinterface

export class ExecuteInTerminalById implements ExecutionBehaviour
  var id: number = -1
  def new(id: number)
  enddef
  def Execute(command: Command)
    echo winnr()
    echo command.name
    echo command.command
  enddef
endclass

export class ExecuteInTerminalByDirection implements ExecutionBehaviour
  var direction: string = 'undefined'
  def new(direction: string)
  enddef
  def Execute(command: Command)
    echo command.name
    echo command.command
  enddef
endclass

export class Assignment
  static var assignments: list<string> = []
  static var assignments_keys = []

  var key: string
  var command: Command
  var executionBehaviour: ExecutionBehaviour
  var range: AssignmentRange
  var bind: AssignmentBinding

  def new(key: string, command: Command, executionBehaviour: ExecutionBehaviour, range: AssignmentRange=AssignmentRange.Global)
    this.key = key
    this.command = command
    this.executionBehaviour = executionBehaviour
    this.range = range
    extend(Assignment.assignments, [ this.command.name ])
    extend(Assignment.assignments_keys, [ this.command.name ] )
  enddef
endclass

var c = Command.new("CloseOther", ":call CloseOther()<cr>")
var eb = ExecuteInTerminalByDirection.new('l')
Assignment.new("<F8>", c, eb, AssignmentRange.Global)

var s = Command.new("Status", ":call GitStatus()<cr>")
Assignment.new("<leader>gs", s, eb)
