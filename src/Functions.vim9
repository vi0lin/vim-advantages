export class Storage
  var leaf = Leaf.new()
  def Print()
    echo this.leaf.ToDict()
  enddef
  def ToDict(): dict<any>
    return this.leaf.ToDict()
  enddef
endclass

export def New(storage: Storage, object: Leaf)
  extend(storage.leaf.leaves, [ object ])
enddef

export def g:Display()
  echo buffers.ToDict()
  tabs.Print()
  windows.Print()
enddef

export def BufNew()
  New(buffers, Buffer.new(bufnr(), winnr(), tabpagenr()))
enddef

export def TabNew()
  New(tabs, Tab.new(bufnr(), winnr(), tabpagenr()))
enddef

export def WinNew()
  New(windows, Window.new(winnr()))
enddef

export def VimEnter()
  New(globals, Global.new(bufnr(), winnr(), tabpagenr()))
enddef

export def WinClosed()
  windows.remove(winnr())
enddef

export def TabClosed()
  tabs.remove(tabnr())
enddef


export var globals: Storage = Storage.new()
export var tabs: Storage = Storage.new()
export var windows: Storage = Storage.new()
export var buffers: Storage = Storage.new()

