export class Leaf extends Dump
  var leaves: list<Leaf> = []
  var nr: number
  var parent: number
  def FindByNr(nr: number): Leaf
    var filtered = filter(copy(this.leaves), (_, v) => v.nr == nr)[0]
    return filtered
  enddef
  def FindByParent(nr: number): Leaf
    var filtered = filter(copy(this.leaves), (_, v) => v.parent == nr)[0]
    return filtered
  enddef
  def Find(nr: number): Leaf
    return this.FindByNr(nr)
  enddef
  def AddRange(leaves: list<Leaf>): Leaf
    call extend(this.leaves, leaves)
    return this
  enddef
  def Add(nr: number): Leaf
    call extend(this.leaves, Leaf.new().SetNr(nr))
    return this
  enddef
  def New(nr: number): Leaf
    call Add(nr)
    return this
  enddef
  def Remove(nr: number)
	  remove(this.leaves, nr)
  enddef
  def SetParent(nr: number): Leaf
    this.parent = nr
    return this
  enddef
  def SetNr(nr: number): Leaf
    this.nr = nr
    return this
  enddef
  # def Print()
  #   echo this.nr
  # enddef
  def ToDict(): dict<any>
    return {
      nr: this.nr,
      parent: this.parent,
      leaves: this.leaves
    }
  enddef
endclass

