def Key2Notation(key: string): string
    var nr = -1
    var c = ""
    if type(key) == v:t_number
        nr = char2nr(key)
        c = nr2char(nr)
        # c = nr .. ""
    else
        c = key           # already string from getcharstr()
        nr = char2nr(c)
        # nr = c .. ""
    endif
    # echo "nr: " .. nr
    # echo "c: "  .. c
    if nr >= 0 && nr <= 31
        # Ctrl + letter/symbol
        if nr == 0      | return '<Nul>'     | endif
        if nr == 27     | return '<Esc>'     | endif
        var letter = nr2char(nr + 64)       # 1 в†’ A, 2 в†’ B, вЂ¦
        return '<C-' .. toupper(letter) .. '>'
    endif
    if c =~ '^[[:print:]]$'
        if c == ' '     | return '<Space>'   | endif
        if c == "\<Tab>"| return '<Tab>'     | endif
        return c
    endif
    # Try to guess function keys / modified fx from common term sequences
    # (very incomplete вЂ“ terminals differ!)
    var seq = substitute(c, "\<", '', 'g')   # just in case
    if seq =~# '^[[1;[1-9]*[A-HOPZ~]$' || seq =~# '^O[A-Z]' || seq =~# '^\[\[.\+$'
        # Many <Fx>, <S-Fx>, <C-Fx> land here
        return '<' .. substitute(seq, '^[^[]*\[\[=\?', '', '') .. '>'   # crude
    endif
    # Fallback: show hex escape
    var hex = ''
    var add: list<number> = []
    for x in range(0, strlen(c) - 1)
      extend(add, [ char2nr(c[x]) ] )
      # echo "->" .. char2nr(c[x] )
      # echo printf('\x%02x', char2nr(c[i]))
    endfor
    var name = input("Name: ")
    echo ""
    for i in range(0, strlen(c) - 1)
        hex ..= printf('\x%02x', char2nr(c[i]))
    endfor
    var specifics = []
    specifics[0] = name
    specifics[1] = add
    specifics[2] = hex
    extend(keys, [ specifics ])
    return printf('<%s>', hex)
enddef

def KeySpecs(key: string): string
    var nr = -1
    var c = ""
    if type(key) == v:t_number
        nr = char2nr(key)
        c = nr2char(nr)
        # c = nr .. ""
    else
        c = key           # already string from getcharstr()
        nr = char2nr(c)
        # nr = c .. ""
    endif
    # echo "nr: " .. nr
    # echo "c: "  .. c
    if nr >= 0 && nr <= 31
        # Ctrl + letter/symbol
        if nr == 0      | return '<Nul>'     | endif
        if nr == 27     | return '<Esc>'     | endif
        var letter = nr2char(nr + 64)       # 1 в†’ A, 2 в†’ B, вЂ¦
        return '<C-' .. toupper(letter) .. '>'
    endif
    if c =~ '^[[:print:]]$'
        if c == ' '     | return '<Space>'   | endif
        if c == "\<Tab>"| return '<Tab>'     | endif
        return c
    endif
    # Try to guess function keys / modified fx from common term sequences
    # (very incomplete вЂ“ terminals differ!)
    var seq = substitute(c, "\<", '', 'g')   # just in case
    if seq =~# '^[[1;[1-9]*[A-HOPZ~]$' || seq =~# '^O[A-Z]' || seq =~# '^\[\[.\+$'
        # Many <Fx>, <S-Fx>, <C-Fx> land here
        return '<' .. substitute(seq, '^[^[]*\[\[=\?', '', '') .. '>'   # crude
    endif
    # Fallback: show hex escape
    var hex = ''
    var add: list<number> = []
    for x in range(0, strlen(c) - 1)
      extend(add, [ char2nr(c[x]) ] )
      # echo "->" .. char2nr(c[x] )
      # echo printf('\x%02x', char2nr(c[i]))
    endfor
    var name = input("Name: ")
    echo ""
    for i in range(0, strlen(c) - 1)
        hex ..= printf('\x%02x', char2nr(c[i]))
    endfor
    var specifics = []
    specifics[0] = name
    specifics[1] = add
    specifics[2] = hex
    return Pretty(specifics)
    # return printf('<%s>', hex)
enddef

