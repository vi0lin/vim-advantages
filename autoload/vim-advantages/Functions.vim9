export class Buffer extends Dump
  var bufnr: number
  # static def Find(nr: number): Leaf
  #   return filter(copy(Branch.Buffers.leaves), 'v:val =~ ' .. nr)[0]
  # enddef
  def new(bufnr: number)
    this.bufnr = bufnr
  enddef
  def Print()
    echo Pretty(this.ToDict())
  enddef
  def ToDict(): dict<any>
    return {
      bufnr: this.bufnr,
    }
  enddef
endclass

export class Window extends Dump
  var winnr: number
  var tabpagenr: number
  var bufnr: number
  def new(winnr: number, tabpagenr: number)
    this.winnr = winnr
    this.tabpagenr = tabpagenr
  enddef
  def SetBuf(bufnr: number)
    this.bufnr = bufnr
  enddef
  def ToDict(): dict<any>
    return {
      winnr: this.winnr,
      tabpagenr: this.tabpagenr,
      bufnr: this.bufnr,
    }
  enddef
  def GetBuffer(): Buffer
    return Storage.Buffers.Find(this.bufnr)
  enddef
endclass

export class Tab extends Dump
  var tabpagenr: number
  var windows: list<Window>
  def new(tabpagenr: number)
    this.tabpagenr = tabpagenr
  enddef
  def ToDict(): dict<any>
    return {
      tabpagenr: this.tabpagenr,
      windows: this.windows
    }
  enddef
  def Win(winnr: number): any
    this.RefreshWins()
    var filtered = filter(copy(this.windows), (_, v) => v.winnr == winnr)[0]
    if len(filtered) > 0
      return filtered[0]
    else
      return null
    endif
  enddef
  def RefreshWins(): Tab
    this.windows = []
    for w in range(1, winnr('$'))
      extend(this.windows, [ Window.new(w, tabpagenr()) ])
    endfor
    return this
  enddef
endclass

export class Instance extends Dump
  var tabs: list<Tab> = []
  def new()
    this.RefreshTabs()
  enddef
  def Tab(tabpagenr: number): any
    this.RefreshTabs()
    var filtered = filter(copy(this.tabs), (_, v) => v.tabpagenr == tabpagenr)
    if len(filtered) > 0
      return filtered[0]
    else 
      return null
    endif
  enddef
  def RefreshTabs(): Instance
    this.tabs = []
    for t in range(1, tabpagenr('$'))
      extend(this.tabs, [ Tab.new(t) ])
    endfor
    return this
  enddef
  def ToDict(): dict<any>
    return {
      instance_nr: this.instance_nr,
      tabs: this.tabs,
    }
  enddef
endclass

def Pretty(d: any, indent: number = 2, level: number = 0): string
  var prefix = repeat(' ', level * indent)
  var next_prefix = repeat(' ', (level + 1) * indent)
  if d->type() == v:t_dict
    if d->empty()
      return '{}'
    endif
    var items = []
    for [k, v] in d->items()
      items->add($'{next_prefix}{k->string()}: {Pretty(v, indent, level + 1)}')
    endfor
    return "{\n" .. items->join(",\n") .. $"\n{prefix}}}"
  elseif d->type() == v:t_list
    if d->empty()
      return '[]'
    endif
    var items = []
    for v in d
      items->add(Pretty(v, indent, level + 1))
    endfor
    return "[\n" .. next_prefix .. items->join(",\n" .. next_prefix) .. $"\n{prefix}]"
  else
    # string, number, bool, v:none, ...
    return d->string()
  endif
enddef

