export def g:GetKeys()
  var keys: list<any> = []
  var from: number = 1
  var to: number = 12
  #extend(keys, g:PutKeyPerformed("<S-A-F%d>", filter(range(from, to), 'index([6], v:val) == 0')))
  extend(keys, g:PutKeyPerformed("<F%d>", range(from, to)))
  extend(keys, g:PutKeyPerformed("<C-F%d>", range(from, to)))
  extend(keys, g:PutKeyPerformed("<S-F%d>", range(from, to)))
  # extend(keys, g:PutKeyPerformed("<A-F%d>", range(from, to)))
  extend(keys, g:PutKeyPerformed("<C-S-F%d>", range(from, to)))
  extend(keys, g:PutKeyPerformed("<S-A-F%d>", filter(range(from, to), '6 != v:val')))
  extend(keys, g:PutKeyPerformed("<C-S-A-F%d>", range(from, to)))
  # extend(keys, g:PutKeyPerformed("<C-A-F%d>", range(from, to)))
  # put = keys
  extend(all_keys, keys)
  # put = Pretty(keys)
  put = [ keys ]
  # norm `[v`]=`]o
enddef

export def g:FindKeyPerform()
  while v:true
    echo g:FindKey()
  endwhile
enddef

export def g:FindKey(): any
  var keycharstr = getcharstr()
  for k in all_keys
    if k[1] == keycharstr
      return k[0]
    endif
  endfor
  return null
enddef

export def g:PutKeyPerformed(formatstring: string, range: list<number>): list<any>
    var nr = -1
    var name: string = ""
    var hex: list<number> = []
    var add: string = ''
    var result: list<any> = []
    for f in range

      echo printf(formatstring, f)

      var key: list<any> = []

      var pocket_plain: list<any> = []
      extend(pocket_plain, [ printf(formatstring, f) ] )
      var keycharstr = getcharstr()
      # var keychar = getchar()

      var pocket_hex: string = ''
      for i in range(0, strlen(keycharstr) - 1)
          pocket_hex ..= printf('\x%02x', char2nr(keycharstr[i]))
      endfor

      var pocket_number: list<any> = []
      for x in range(0, strlen(keycharstr) - 1)
        extend(pocket_number, [ char2nr(keycharstr[x]) ] )
      endfor

      extend(key, pocket_plain )
      extend(key, [ keycharstr ] )
      # extend(key, [ keychar ] )
      extend(key, [ pocket_number ] )
      extend(key, [ pocket_hex ] )
      extend(result, [ key ] )
    endfor
    return result
    # put = KeySpecs(getcharstr()) .. ','
    # norm `[v`]=`]o
enddef

export def g:PutKey()
    put = KeySpecs(getcharstr()) .. ','
    norm `[v`]=`]o
enddef

export def g:CheckKeys()
  while v:true
    Key2Notation(getcharstr())
    echo Pretty(keys)
  endwhile
enddef

export def g:K(): string
  return Pretty(keys)
enddef

